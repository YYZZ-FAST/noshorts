{
  "manifest_version": 3,
  "name": "No Shorts",
  "version": "1.0",
  "description": "Removes YouTube Shorts from the interface.",
  "icons": {
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ]
}